# UI
background-opacity = 0.8
background-blur-radius = 60
cursor-style = bar
cursor-style-blink = true
cursor-click-to-move = true
# theme = custom
theme = custom-cat
# theme = techbase
# theme = teide
# theme = Black Metal (Bathory)
# theme = oldworld
# theme = techbase
# theme = yugen
# theme = rose-pine
# background = #0b0b12
# background  = #141617
background = #101010

# theme = cyberdream
title = Ghostty 👻
macos-titlebar-style = hidden
macos-titlebar-proxy-icon      = hidden
# cursor-color = #ACA1CF

# -------
#blueprint
# chalkboard
# microchip
# glass
# holographic
# paper
# retro
# xray
macos-icon = xray

# Window
maximize = true
window-theme = ghostty
window-padding-x = 0
window-padding-y = 0
window-padding-balance = false
window-save-state = always
window-padding-color = extend-always
# window-decoration = none

# Font
font-size = 15
# font-family = "CaskaydiaCove Nerd Font"
# font-family = "SFMono Nerd Font Mono"
# font-family = "IBM Plex Mono"
font-family-italic = "CartographCF Nerd Font"
font-family-bold-italic = "CartographCF Nerd Font"
