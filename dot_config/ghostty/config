# font-family = "Comic Mono"
# font-family = "ComicShannsMono Nerd Font"
font-family = "Zed Plex Mono"
# font-family = "BlexMono Nerd Font"
font-style = Medium


adjust-cell-height = 30%
# adjust-cursor-height = 4

font-feature = +calt
font-feature = +ss02

# 使用更粗的笔触绘制字体
font-thicken = true

# Font features
font-feature = ss02
font-feature = ss07
font-feature = ss11
font-feature = ss14
font-feature = ss16
font-feature = zero
font-feature = ss04
font-feature = ss08
font-feature = ss11
font-feature = ss17

# keybind = alt+arrow_left=unbind
# keybind = alt+arrow_right=unbind
# keybind = alt+arrow_up=unbind
# keybind = alt+arrow_down=unbind
keybind = ctrl+,=unbind
keybind = ctrl+.=unbind

# Keybinds
keybind = ctrl+shift+w=toggle_fullscreen
keybind = super+shift+r=reload_config
keybind = super+enter=toggle_maximize

# --------- Neovim -------
# 保存
keybind = super+s=text:\x13
keybind = super+d=text:\x04
keybind = super+u=text:\x15
keybind = super+o=text:\x0f
# --------- Neovim --------

# --------- Keybinds Tmux ---------
keybind = super+Digit1=text:\x01\x31
keybind = super+Digit2=text:\x01\x32
keybind = super+Digit3=text:\x01\x33
keybind = super+Digit4=text:\x01\x34
keybind = super+Digit5=text:\x01\x35
keybind = super+Digit6=text:\x01\x36
keybind = super+Digit7=text:\x01\x37
keybind = super+Digit8=text:\x01\x38
keybind = super+Digit9=text:\x01\x39
keybind = super+t=text:\x01\x63
keybind = super+x=text:\x01\x78
keybind = super+,=text:\x01\x2c
# keybind = super+l=text:\x01\x73 #Ctrl + a + s 列出所有会话
keybind = super+l=text:\x01\x77 #Ctrl + a + w 列出所有窗口
keybind = super+k=text:\x01\x4b
# 放大当前窗口
keybind = super+z=text:\x01\x7a

